<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ControlIT - Registro de Horas</title>
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/calendar.css">
  <link rel="stylesheet" href="/css/panels.css">
</head>
<body>
  <div class="container">

    <!-- Header with global simulation toggle -->
    <header class="header">
      <div class="header-top">
        <div class="header-brand">
          <h1><i class="fas fa-clock"></i> ControlIT - Registro de Horas</h1>
          <p>Automatiza el registro de tus horas laborales de forma eficiente y segura</p>
        </div>
        <div class="header-actions">
          <div class="simulation-toggle">
            <span class="simulation-toggle__label">
              <i class="fas fa-bolt"></i> Simulación
            </span>
            <button
              type="button"
              id="simulation-toggle-btn"
              class="toggle-switch <%= dryRun ? 'toggle-switch--active' : '' %>"
              aria-pressed="<%= dryRun %>"
              aria-label="Modo simulación"
            >
              <span class="toggle-switch__thumb"></span>
            </button>
          </div>
          <button type="button" id="settings-btn" class="btn btn-ghost btn-sm" aria-label="Configuración de horario" title="Configuración de horario">
            <i class="fas fa-cog"></i>
          </button>
          <% if (typeof currentUser !== 'undefined' && currentUser) { %>
          <span class="current-user" title="<%= currentUser %>">
            <i class="fas fa-user-circle"></i>
            <span class="current-user__name"><%= currentUser %></span>
          </span>
          <% } %>
          <form method="POST" action="/logout" style="display:inline;">
            <button type="submit" class="btn btn-ghost btn-sm" aria-label="Cerrar sesión" title="Cerrar sesión">
              <i class="fas fa-sign-out-alt"></i>
            </button>
          </form>
        </div>
      </div>
    </header>

    <!-- Settings Modal -->
    <div id="settings-overlay" class="modal-overlay" hidden aria-modal="true" role="dialog" aria-labelledby="settings-title">
      <div class="modal-container">
        <div class="modal-header">
          <h2 id="settings-title"><i class="fas fa-cog"></i> Configuración de Horario</h2>
          <button type="button" id="settings-close-btn" class="btn btn-ghost btn-sm" aria-label="Cerrar">
            <i class="fas fa-times"></i>
          </button>
        </div>
        <div class="modal-body">
          <div id="settings-alert"></div>
          <form id="settings-form">
            <div class="settings-section">
              <h3><i class="fas fa-sun"></i> Horario de Invierno (días normales)</h3>
              <div class="settings-row">
                <div class="form-group">
                  <label>Entrada</label>
                  <div class="time-inputs">
                    <input type="number" id="s-winter-start-hour" min="0" max="23" class="input-narrow" placeholder="HH">
                    <span>:</span>
                    <input type="number" id="s-winter-start-minute" min="0" max="59" class="input-narrow" placeholder="MM">
                  </div>
                </div>
                <div class="form-group">
                  <label>Duración</label>
                  <div class="time-inputs">
                    <input type="number" id="s-winter-length-hours" min="0" max="23" class="input-narrow" placeholder="HH">
                    <span>h</span>
                    <input type="number" id="s-winter-length-minutes" min="0" max="59" class="input-narrow" placeholder="MM">
                    <span>m</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="settings-section">
              <h3><i class="fas fa-utensils"></i> Comida</h3>
              <div class="settings-row">
                <div class="form-group">
                  <label>Inicio</label>
                  <div class="time-inputs">
                    <input type="number" id="s-lunch-start-hour" min="0" max="23" class="input-narrow" placeholder="HH">
                    <span>:</span>
                    <input type="number" id="s-lunch-start-minute" min="0" max="59" class="input-narrow" placeholder="MM">
                  </div>
                </div>
                <div class="form-group">
                  <label>Duración</label>
                  <div class="time-inputs">
                    <input type="number" id="s-lunch-length-hours" min="0" max="23" class="input-narrow" placeholder="HH">
                    <span>h</span>
                    <input type="number" id="s-lunch-length-minutes" min="0" max="59" class="input-narrow" placeholder="MM">
                    <span>m</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="settings-section">
              <h3><i class="fas fa-umbrella-beach"></i> Horario de Verano (viernes y periodo estival)</h3>
              <div class="settings-row">
                <div class="form-group">
                  <label>Entrada</label>
                  <div class="time-inputs">
                    <input type="number" id="s-summer-start-hour" min="0" max="23" class="input-narrow" placeholder="HH">
                    <span>:</span>
                    <input type="number" id="s-summer-start-minute" min="0" max="59" class="input-narrow" placeholder="MM">
                  </div>
                </div>
                <div class="form-group">
                  <label>Duración</label>
                  <div class="time-inputs">
                    <input type="number" id="s-summer-length-hours" min="0" max="23" class="input-narrow" placeholder="HH">
                    <span>h</span>
                    <input type="number" id="s-summer-length-minutes" min="0" max="59" class="input-narrow" placeholder="MM">
                    <span>m</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="settings-section">
              <h3><i class="fas fa-calendar-alt"></i> Periodo Estival</h3>
              <div class="settings-row">
                <div class="form-group">
                  <label>Inicio (día/mes)</label>
                  <div class="time-inputs">
                    <input type="number" id="s-summer-start-day" min="1" max="31" class="input-narrow" placeholder="DD">
                    <span>/</span>
                    <input type="number" id="s-summer-start-month" min="1" max="12" class="input-narrow" placeholder="MM">
                  </div>
                </div>
                <div class="form-group">
                  <label>Fin (día/mes)</label>
                  <div class="time-inputs">
                    <input type="number" id="s-summer-end-day" min="1" max="31" class="input-narrow" placeholder="DD">
                    <span>/</span>
                    <input type="number" id="s-summer-end-month" min="1" max="12" class="input-narrow" placeholder="MM">
                  </div>
                </div>
              </div>
            </div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button" id="settings-reset-btn" class="btn btn-ghost btn-sm">
            <i class="fas fa-undo"></i> Restaurar valores por defecto
          </button>
          <div class="modal-footer-actions">
            <button type="button" id="settings-cancel-btn" class="btn btn-ghost">Cancelar</button>
            <button type="button" id="settings-save-btn" class="btn btn-primary">
              <i class="fas fa-save"></i> Guardar
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Loading Overlay -->
    <div id="loading-overlay" class="loading-overlay" style="display: none;">
      <div class="loading-content">
        <div class="loading-spinner"></div>
        <div class="loading-text">Procesando solicitud...</div>
        <div class="loading-subtext">Esto puede tomar unos momentos</div>
      </div>
    </div>

    <!-- Alert Messages -->
    <div id="alert-container"></div>
    <% if (typeof submitted !== 'undefined' && submitted) { %>
      <div class="alert alert-success" role="status" aria-live="polite">
        <i class="fas fa-check-circle"></i>
        <div>
          <strong>Proceso completado:</strong> Se ha procesado el rango
          <%= startDate %> a <%= endDate %><%= dryRun ? ' (simulado)' : '' %>.
        </div>
      </div>
    <% } %>

    <!-- Stats Bar (compact) -->
    <% if (typeof stats !== 'undefined') { %>
    <div class="stats-bar">
      <div class="stats-bar__item">
        <span class="stats-bar__value stats-bar__value--success"><%= stats.registered %></span>
        <span class="stats-bar__label">Registrados</span>
      </div>
      <div class="stats-bar__sep" aria-hidden="true"></div>
      <div class="stats-bar__item">
        <span class="stats-bar__value stats-bar__value--error"><%= stats.pending %></span>
        <span class="stats-bar__label">Pendientes</span>
      </div>
      <div class="stats-bar__sep" aria-hidden="true"></div>
      <div class="stats-bar__item">
        <span class="stats-bar__value stats-bar__value--warning"><%= stats.holiday %></span>
        <span class="stats-bar__label">Festivos</span>
      </div>
      <div class="stats-bar__sep" aria-hidden="true"></div>
      <div class="stats-bar__item">
        <span class="stats-bar__value stats-bar__value--info"><%= stats.vacation %></span>
        <span class="stats-bar__label">Vacaciones</span>
      </div>
      <% if (stats.pending > 0) { %>
      <button
        type="button"
        id="fill-pending-btn"
        class="btn btn-warning btn-sm"
        data-first-pending="<%= firstPending %>"
      >
        <i class="fas fa-bolt"></i> Registrar <%= stats.pending %> pendientes
      </button>
      <% } %>
    </div>
    <% } %>

    <!-- Action Card: Form + Results combined -->
    <div class="card">
      <div class="card-header">
        <i class="fas fa-calendar-plus"></i>
        <h2>Registrar Horas</h2>
      </div>

      <form id="hours-form" method="POST" action="/submit" novalidate>
        <!-- Hidden checkbox synced with global toggle -->
        <input
          type="checkbox"
          id="dryRun"
          name="dryRun"
          class="sr-only"
          <%= dryRun ? 'checked' : '' %>
          aria-hidden="true"
          tabindex="-1"
        >

        <div class="form-row">
          <div class="form-group">
            <label for="startDate">
              <i class="fas fa-calendar-day"></i> Desde
            </label>
            <input
              type="date"
              id="startDate"
              name="startDate"
              required
              value="<%= startDate ?? '' %>"
              aria-describedby="startDate-help"
            >
            <div id="startDate-help" class="sr-only">Fecha de inicio del período a registrar</div>
          </div>

          <div class="form-group">
            <label for="endDate">
              <i class="fas fa-calendar-day"></i> Hasta
            </label>
            <input
              type="date"
              id="endDate"
              name="endDate"
              required
              value="<%= endDate ?? '' %>"
              aria-describedby="endDate-help"
            >
            <div id="endDate-help" class="sr-only">Fecha de fin del período a registrar</div>
          </div>

          <div class="form-action">
            <button type="submit" id="submit-btn" class="btn btn-primary">
              <i id="submit-icon" class="fas <%= dryRun ? 'fa-eye' : 'fa-paper-plane' %>"></i>
              <span id="submit-text"><%= dryRun ? 'Simular' : 'Registrar' %></span>
            </button>
          </div>
        </div>
      </form>

      <!-- Results (inline, only shown after action) -->
      <% if (results && results.length > 0) { %>
      <%
        const nProcessed = results.filter(r => r.status === 'submitted' || r.status === 'dry-run').length;
        const nSubmitted = results.filter(r => r.status === 'submitted').length;
        const nSimulated = results.filter(r => r.status === 'dry-run').length;
      %>
      <div class="results-section">
        <div class="results-divider"><span>Resultados</span></div>
        <div class="results-row">
          <div class="results-stats">
            <div class="result-item">
              <span class="result-value"><%= nProcessed %></span>
              <span class="result-label">Procesados</span>
            </div>
            <div class="result-item">
              <span class="result-value result-value--success"><%= nSubmitted %></span>
              <span class="result-label">Enviados</span>
            </div>
            <div class="result-item">
              <span class="result-value result-value--simulated"><%= nSimulated %></span>
              <span class="result-label">Simulados</span>
            </div>
          </div>
          <a href="/" class="btn btn-ghost btn-sm">
            <i class="fas fa-times"></i> Limpiar
          </a>
        </div>
        <% if (nSimulated > 0) { %>
        <div class="alert alert-warning" style="margin-top: 1rem; margin-bottom: 0;">
          <i class="fas fa-bolt"></i>
          <div><strong><%= nSimulated %> días simulados</strong> — no se han enviado datos al sistema.</div>
        </div>
        <% } %>
        <% const resultsWithTimes = results.filter(r => r.workStart); %>
        <% if (resultsWithTimes.length > 0) { %>
        <details class="results-detail" open>
          <summary class="results-detail__toggle">
            <i class="fas fa-list"></i> Detalle por día (<%= resultsWithTimes.length %>)
            <i class="fas fa-chevron-down results-detail__chevron"></i>
          </summary>
          <div class="results-detail__table-wrap">
            <table class="results-table">
              <thead>
                <tr>
                  <th>Fecha</th>
                  <th>Entrada</th>
                  <th>Salida</th>
                  <th>Comida</th>
                  <th class="results-table__col-tipo">Tipo</th>
                </tr>
              </thead>
              <tbody>
                <% resultsWithTimes.forEach(function(r) { %>
                <tr class="results-table__row results-table__row--<%= r.status %>">
                  <td class="results-table__date"><%= r.date %></td>
                  <td><%= r.workStart %></td>
                  <td><%= r.workEnd %></td>
                  <td><%= r.lunchStart ? (r.lunchStart + ' – ' + r.lunchEnd) : '—' %></td>
                  <td class="results-table__col-tipo">
                    <span class="results-table__badge results-table__badge--<%= r.isShortDay ? 'short' : 'full' %>">
                      <%= r.isShortDay ? 'Intensiva' : 'Partida' %>
                    </span>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </details>
        <% } %>
      </div>
      <% } %>
    </div>

    <!-- Leave Days & Vacation Requests Panel -->
    <%
      const _hasLeave = leaveDays && leaveDays.length > 0;
      const _hasVacation = typeof vacationRequests !== 'undefined' && vacationRequests && vacationRequests.length > 0;
    %>
    <% if (_hasLeave || _hasVacation) { %>
    <%
      const _td = new Date();
      const today_iso = `${_td.getFullYear()}-${String(_td.getMonth()+1).padStart(2,'0')}-${String(_td.getDate()).padStart(2,'0')}`;
      const _leave = leaveDays || [];
      const upcomingLeave = _leave.filter(l => !l.end || l.end >= today_iso);
      const pastLeave     = _leave.filter(l => l.end && l.end < today_iso);
      const _vac = (typeof vacationRequests !== 'undefined' && vacationRequests) || [];
      const upcomingVacation = _vac.filter(v => !v.end || v.end >= today_iso);
      const pastVacation     = _vac.filter(v => v.end && v.end < today_iso);
      const totalUpcoming = upcomingLeave.length + upcomingVacation.length;
    %>
    <details class="card leave-days-panel">
      <summary class="card-header card-header--toggle">
        <i class="fas fa-umbrella-beach"></i>
        <h2>Permisos, Vacaciones y Ausencias</h2>
        <% if (totalUpcoming > 0) { %>
        <span class="leave-badge"><%= totalUpcoming %> activo<%= totalUpcoming !== 1 ? 's' : '' %></span>
        <% } %>
        <i class="fas fa-chevron-down card-header__chevron"></i>
      </summary>
      <div class="leave-days-list">
        <% upcomingVacation.forEach(function(v) { %>
        <div class="leave-day-item leave-day-item--<%= v.stateCode === 3 ? 'vacation-approved' : 'vacation-pending' %>">
          <div class="leave-day-icon">
            <i class="fas fa-<%= v.stateCode === 3 ? 'plane' : 'hourglass-half' %>"></i>
          </div>
          <div class="leave-day-info">
            <span class="leave-day-type"><%= v.type %></span>
            <span class="leave-day-dates">
              <%= v.start %><% if (v.end && v.end !== v.start) { %> → <%= v.end %><% } %>
            </span>
          </div>
          <span class="leave-day-state"><%= v.state %></span>
        </div>
        <% }); %>
        <% upcomingLeave.forEach(function(l) { %>
        <div class="leave-day-item leave-day-item--<%= l.stateCode === 3 ? 'approved' : 'pending' %>">
          <div class="leave-day-icon">
            <i class="fas fa-<%= l.stateCode === 3 ? 'check-circle' : 'clock' %>"></i>
          </div>
          <div class="leave-day-info">
            <span class="leave-day-type"><%= l.type %></span>
            <span class="leave-day-dates">
              <%= l.start %><% if (l.end && l.end !== l.start) { %> → <%= l.end %><% } %>
            </span>
          </div>
          <span class="leave-day-state"><%= l.state %></span>
        </div>
        <% }); %>
        <% if (pastVacation.length > 0 || pastLeave.length > 0) { %>
        <details class="leave-days-past">
          <summary>Ver <%= pastVacation.length + pastLeave.length %> registro<%= (pastVacation.length + pastLeave.length) !== 1 ? 's' : '' %> pasado<%= (pastVacation.length + pastLeave.length) !== 1 ? 's' : '' %></summary>
          <% pastVacation.forEach(function(v) { %>
          <div class="leave-day-item leave-day-item--past">
            <div class="leave-day-icon"><i class="fas fa-plane"></i></div>
            <div class="leave-day-info">
              <span class="leave-day-type"><%= v.type %></span>
              <span class="leave-day-dates">
                <%= v.start %><% if (v.end && v.end !== v.start) { %> → <%= v.end %><% } %>
              </span>
            </div>
            <span class="leave-day-state"><%= v.state %></span>
          </div>
          <% }); %>
          <% pastLeave.forEach(function(l) { %>
          <div class="leave-day-item leave-day-item--past">
            <div class="leave-day-icon"><i class="fas fa-history"></i></div>
            <div class="leave-day-info">
              <span class="leave-day-type"><%= l.type %></span>
              <span class="leave-day-dates">
                <%= l.start %><% if (l.end && l.end !== l.start) { %> → <%= l.end %><% } %>
              </span>
            </div>
            <span class="leave-day-state"><%= l.state %></span>
          </div>
          <% }); %>
        </details>
        <% } %>
      </div>
    </details>
    <% } %>

    <!-- Calendar Section -->
    <% if (calendarData && calendarData.length > 0) { %>
    <div class="card calendar-container">
      <div class="card-header">
        <i class="fas fa-calendar-alt"></i>
        <h2>Calendario de Horas</h2>
      </div>

      <div class="calendar-header">
        <div class="calendar-title">Vista Anual</div>
        <div class="legend" aria-label="Leyenda y filtros de calendario">
          <div class="legend-item" role="button" tabindex="0" data-status="registered" aria-pressed="true">
            <div class="legend-color registered" aria-hidden="true"></div>
            <span>Registrado</span>
          </div>
          <div class="legend-item" role="button" tabindex="0" data-status="pending" aria-pressed="true">
            <div class="legend-color pending" aria-hidden="true"></div>
            <span>Pendiente</span>
          </div>
          <div class="legend-item" role="button" tabindex="0" data-status="holiday" aria-pressed="true">
            <div class="legend-color holiday" aria-hidden="true"></div>
            <span>Festivo</span>
          </div>
          <div class="legend-item" role="button" tabindex="0" data-status="vacation" aria-pressed="true">
            <div class="legend-color vacation" aria-hidden="true"></div>
            <span>Vacaciones</span>
          </div>
          <div class="legend-item" role="button" tabindex="0" data-status="vacation-pending" aria-pressed="true">
            <div class="legend-color vacation-pending" aria-hidden="true"></div>
            <span>Vacaciones solicitadas</span>
          </div>
          <div class="legend-item" role="button" tabindex="0" data-status="leave" aria-pressed="true">
            <div class="legend-color leave" aria-hidden="true"></div>
            <span>Permiso</span>
          </div>
          <div class="legend-item" role="button" tabindex="0" data-status="leave-pending" aria-pressed="true">
            <div class="legend-color leave-pending" aria-hidden="true"></div>
            <span>Permiso pendiente</span>
          </div>
          <div class="legend-item" role="button" tabindex="0" data-status="simulated" aria-pressed="true">
            <div class="legend-color simulated" aria-hidden="true"></div>
            <span>Simulado ⚡</span>
          </div>
        </div>
      </div>

      <%
        const groupedByMonth = {};
        calendarData.forEach(day => {
          const monthKey = day.date.slice(0, 7); // "YYYY-MM"
          if (!groupedByMonth[monthKey]) groupedByMonth[monthKey] = [];
          groupedByMonth[monthKey].push(day);
        });

        const monthNames = {
          "01": "Enero", "02": "Febrero", "03": "Marzo", "04": "Abril",
          "05": "Mayo", "06": "Junio", "07": "Julio", "08": "Agosto",
          "09": "Septiembre", "10": "Octubre", "11": "Noviembre", "12": "Diciembre"
        };

        const _now = new Date();
        const today = `${_now.getFullYear()}-${String(_now.getMonth()+1).padStart(2,'0')}-${String(_now.getDate()).padStart(2,'0')}`;
      %>

      <div class="months-grid">
      <% Object.keys(groupedByMonth).sort().forEach(monthKey => {
           const [year, month] = monthKey.split('-');
           const monthLabel = monthNames[month] + ' ' + year;
      %>
        <div class="month-section">
          <h3 class="month-title"><%= monthLabel %></h3>
          <div class="calendar-weekdays">
            <% ['Lun','Mar','Mié','Jue','Vie','Sáb','Dom'].forEach(function(d) { %>
              <div class="calendar-weekday-header"><%= d %></div>
            <% }); %>
          </div>
          <div class="calendar" role="grid" aria-label="Calendario de <%= monthLabel %>">
            <%
              const [fy, fm] = monthKey.split('-').map(Number);
              const firstDayOfMonth = new Date(fy, fm - 1, 1); // local date, avoids UTC parsing
              const offset = (firstDayOfMonth.getDay() + 6) % 7; // Mon=0, ..., Sun=6
              for (let i = 0; i < offset; i++) { %>
              <div class="calendar-day calendar-day--empty" aria-hidden="true"></div>
            <% } %>
            <% groupedByMonth[monthKey].forEach(day => {
                 const dayNumber = day.date.slice(8);
                 const isToday = day.date === today;
                 const isDryRun = Array.isArray(results) && results.some(r => r.date === day.date && r.dryRun);
                 const matchingResult = Array.isArray(results) && results.find(r => r.date === day.date && r.workStart);
                 const classes = ['calendar-day'];
                 if (day.status) classes.push(day.status);
                 if (day.isHoliday) classes.push('holiday');
                 if (isDryRun) classes.push('simulated');
                 if (isToday) classes.push('today');

                 const statusText =
                   day.status === 'holiday' ? 'Día festivo' :
                   day.status === 'vacation' ? 'Vacaciones' :
                   day.status === 'vacation-pending' ? 'Vacaciones solicitadas' :
                   day.status === 'leave' ? 'Permiso' :
                   day.status === 'leave-pending' ? 'Permiso pendiente' :
                   day.status === 'registered' ? 'Horas registradas' :
                   day.status === 'pending' ? 'Horas pendientes' :
                   day.status === 'weekend' ? 'Fin de semana' :
                   day.status === 'future' ? '' :
                   'Sin registro';
                 const timeSuffix = matchingResult
                   ? ` | ${matchingResult.workStart} - ${matchingResult.workEnd}` +
                     (matchingResult.lunchStart ? ` (Comida: ${matchingResult.lunchStart}-${matchingResult.lunchEnd})` : '')
                   : '';
                 const ariaLabel = `${dayNumber} de ${monthLabel}: ${statusText}${isDryRun ? ' (Simulado)' : ''}${timeSuffix}`;
            %>
              <div
                class="<%= classes.join(' ') %>"
                role="gridcell"
                tabindex="0"
                aria-label="<%= ariaLabel %>"
                title="<%= ariaLabel %>"
                data-date="<%= day.date %>"
                data-status="<%= day.status || '' %>"
              >
                <%= dayNumber %>
              </div>
            <% }) %>
          </div>
        </div>
      <% }) %>
      </div>
    </div>
    <% } %>
  </div>

  <!-- Confirm register tooltip (shown before registering a pending day) -->
  <div id="confirm-tooltip" class="undo-tooltip confirm-tooltip" role="dialog" aria-label="Confirmar registro" hidden>
    <span class="undo-tooltip__text"><i class="fas fa-clock"></i> ¿Registrar <span id="confirm-date-label" class="confirm-tooltip__date"></span>?</span>
    <div class="confirm-tooltip__fields">
      <label class="confirm-tooltip__label"><i class="fas fa-sign-in-alt"></i> Entrada</label>
      <input id="confirm-work-start" type="time" class="confirm-tooltip__time-input" />

      <label class="confirm-tooltip__label"><i class="fas fa-sign-out-alt"></i> Salida</label>
      <input id="confirm-work-end" type="time" class="confirm-tooltip__time-input" />

      <label id="confirm-lunch-label" class="confirm-tooltip__label" hidden><i class="fas fa-utensils"></i> Comida</label>
      <div id="confirm-lunch-row" class="confirm-tooltip__time-range" hidden>
        <input id="confirm-lunch-start" type="time" class="confirm-tooltip__time-input" />
        <span>–</span>
        <input id="confirm-lunch-end" type="time" class="confirm-tooltip__time-input" />
      </div>
    </div>
    <div class="undo-tooltip__actions">
      <button id="confirm-register-btn" class="btn btn-primary btn-xs">Registrar</button>
      <button id="confirm-cancel-btn" class="btn btn-ghost btn-xs">Cancelar</button>
    </div>
  </div>

  <!-- Schedule tooltip (shown after single-day simulation) -->
  <div id="schedule-tooltip" class="schedule-tooltip" role="status" aria-live="polite" hidden>
    <div class="schedule-tooltip__content"></div>
  </div>

  <!-- Undo tooltip (shared, moved around via JS) -->
  <div id="undo-tooltip" class="undo-tooltip" role="dialog" aria-label="Eliminar registro" hidden>
    <div id="undo-tooltip__hours" class="undo-tooltip__hours" hidden></div>
    <span class="undo-tooltip__text"><i class="fas fa-trash-alt"></i> ¿Eliminar registro?</span>
    <input id="undo-message-input" class="undo-tooltip__message-input" type="text" placeholder="Motivo (opcional)" maxlength="200" />
    <div class="undo-tooltip__actions">
      <button id="undo-confirm-btn" class="btn btn-danger btn-xs">Sí, borrar</button>
      <button id="undo-cancel-btn" class="btn btn-ghost btn-xs">Cancelar</button>
    </div>
  </div>

  <script src="/app.js"></script>
</body>
</html>
